# Example .env file for ComfyUI
# Copy this to .env and set secure values. Do NOT commit the real .env file.

# Username (server looks for USER, USERNAME, or COMFY_USER)
COMFY_USER=your_username

# Password (server looks for PASSWORD, PASS, or COMFY_PASSWORD)
COMFY_PASSWORD=your_password

# Optional aliases
# USER=your_username
# PASSWORD=your_password

# Optional: example for TLS file paths (if you use TLS via CLI args)
# TLS_CERTFILE=/path/to/cert.pem
# TLS_KEYFILE=/path/to/key.pem
